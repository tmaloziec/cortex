# Cortex — Environment Variables

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b          # or gemma4:26b, gemma4:31b, etc.

# Agent
AGENT_NAME=cortex

# Consciousness Server (optional — agent works without it)
# CS_URL=http://localhost:<port>

# Anthropic fallback (optional — used when Ollama fails)
# ANTHROPIC_API_KEY=sk-ant-...
# USE_ANTHROPIC=false

# Web UI
WEB_PORT=8080
